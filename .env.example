# Everrock Command Center - Environment Config
# Copy this to .env and fill in your values

# Scanner API URL (your VPS)
REACT_APP_SCANNER_API=http://localhost:8420

# Anthropic API Key (for scanner AI scoring)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# PlanetBids Login (for RFP scanner)
PLANETBIDS_EMAIL=your-email@gmail.com
PLANETBIDS_PASSWORD=your-password-here
